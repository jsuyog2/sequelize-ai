{
  "name": "@jsuyog2/sequelize-ai",
  "version": "1.1.1",
  "description": "AI-powered natural language to Sequelize query generator",
  "keywords": [
    "sequelize",
    "ai",
    "nlp",
    "orm",
    "openai",
    "gemini",
    "claude",
    "groq",
    "text-to-sql",
    "nodejs",
    "natural-language",
    "database"
  ],
  "homepage": "https://github.com/jsuyog2/sequelize-ai#readme",
  "bugs": {
    "url": "https://github.com/jsuyog2/sequelize-ai/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jsuyog2/sequelize-ai.git"
  },
  "license": "MIT",
  "author": "Suyog Jadhav",
  "type": "commonjs",
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node build.js",
    "build:watch": "node build.js --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "prepare": "husky",
    "prepublishOnly": "npm run build && npm test && npm run lint"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,html}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@google/generative-ai": "^0.24.1",
    "groq-sdk": "^0.37.0",
    "isolated-vm": "^6.0.2",
    "openai": "^6.25.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "dotenv": "^17.3.1",
    "esbuild": "^0.27.3",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "pg": "^8.20.0",
    "prettier": "^3.8.1",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.7"
  },
  "peerDependenciesMeta": {
    "pg": {
      "optional": true
    },
    "pg-hstore": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
